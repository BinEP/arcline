---
import { articlePreview, site } from '../data/site';
const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div>
			<p class="eyebrow">Arcline</p>
			<h2>Lighting that feels built into the space.</h2>
			<p>
				Custom WLED installs for homes, displays, trees, and everyday spaces in {site.serviceArea}.
			</p>
		</div>
		<div>
			<p class="eyebrow">Contact</p>
			<ul>
				<li><a href={site.phoneHref}>{site.phone}</a></li>
				<li><a href={site.emailHref}>{site.email}</a></li>
				<li><a href={site.blueskyUrl} target="_blank" rel="noreferrer">{site.blueskyHandle}</a></li>
			</ul>
		</div>
		<div>
			<p class="eyebrow">Next up</p>
			<h3>{articlePreview.title}</h3>
			<p>{articlePreview.description}</p>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {site.name}. Installed by {site.founder}.</p>
	</div>
</footer>
<style>
	footer {
		padding: 5rem 1rem 2.5rem;
		background:
			radial-gradient(circle at top left, rgba(72, 149, 239, 0.18), transparent 30%),
			radial-gradient(circle at 85% 0%, rgba(255, 179, 71, 0.14), transparent 20%),
			#07111a;
		color: rgba(234, 240, 255, 0.86);
	}
	.footer-grid {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		gap: 2rem;
	}
	.eyebrow {
		margin: 0 0 0.65rem;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(168, 197, 255, 0.72);
	}
	h2,
	h3 {
		color: white;
	}
	h2 {
		max-width: 16ch;
		font-size: clamp(2rem, 4vw, 3rem);
	}
	h3 {
		font-size: 1.2rem;
		margin-bottom: 0.75rem;
	}
	ul {
		padding: 0;
		margin: 0;
		list-style: none;
	}
	li + li {
		margin-top: 0.65rem;
	}
	a {
		text-decoration: none;
		color: rgba(255, 255, 255, 0.92);
	}
	a:hover {
		color: var(--accent);
	}
	.footer-bottom {
		width: min(1180px, calc(100% - 2rem));
		margin: 2.5rem auto 0;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		color: rgba(214, 222, 246, 0.62);
	}
	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
