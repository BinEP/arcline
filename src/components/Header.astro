---
import HeaderLink from './HeaderLink.astro';
import { navigation, site } from '../data/site';
---

<header>
	<nav>
		<div class="brand">
			<a href="/" class="wordmark">
				<span>{site.name}</span>
				<small>{site.founder}</small>
			</a>
		</div>
		<div class="internal-links">
			{navigation.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
		</div>
		<div class="contact-links">
			<a href={site.phoneHref}>{site.phone}</a>
			<a href={site.emailHref}>Email</a>
			<a href={site.blueskyUrl} target="_blank" rel="noreferrer">Bluesky</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(18px);
		background: rgba(7, 11, 18, 0.72);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	nav {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		padding: calc(env(safe-area-inset-top, 0px) + 0.95rem) 0 0.95rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		flex-wrap: wrap;
	}
	.brand {
		flex: 1 1 15rem;
	}
	.wordmark,
	.wordmark.active {
		display: inline-flex;
		flex-direction: column;
		gap: 0.1rem;
		color: white;
		text-decoration: none;
	}
	.wordmark span {
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.wordmark small {
		color: rgba(218, 227, 255, 0.72);
		font-size: 0.76rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.internal-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		flex: 1 1 28rem;
	}
	nav a {
		padding: 0.7rem 0.95rem;
		color: rgba(237, 242, 255, 0.84);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		border-radius: 999px;
	}
	nav a.active {
		background: rgba(255, 255, 255, 0.08);
		border-bottom-color: transparent;
		color: white;
	}
	.contact-links,
	.contact-links a {
		display: flex;
	}
	.contact-links {
		gap: 0.35rem;
		flex: 1 1 18rem;
		justify-content: flex-end;
		flex-wrap: wrap;
	}
	.contact-links a {
		align-items: center;
		justify-content: center;
		background: rgba(255, 255, 255, 0.06);
	}
	nav a:hover {
		color: white;
		background: rgba(255, 255, 255, 0.1);
	}
	@media (max-width: 720px) {
		nav {
			width: calc(100% - 1rem);
			padding: calc(env(safe-area-inset-top, 0px) + 0.8rem) 0 0.8rem;
			gap: 0.85rem;
		}
		.brand {
			flex-basis: 100%;
		}
		.internal-links {
			justify-content: flex-start;
			order: 3;
			gap: 0.35rem;
			flex: 1 1 100%;
			flex-wrap: nowrap;
			overflow-x: auto;
			padding-bottom: 0.2rem;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
		}
		.internal-links::-webkit-scrollbar {
			display: none;
		}
		.contact-links {
			justify-content: flex-start;
			order: 2;
			flex: 1 1 100%;
			gap: 0.5rem;
		}
		.contact-links a {
			font-size: 0.95rem;
			padding-inline: 0.95rem;
		}
		nav a {
			padding: 0.55rem 0.8rem;
			white-space: nowrap;
		}
		.wordmark small {
			font-size: 0.72rem;
		}
	}
</style>
