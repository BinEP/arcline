---
import SiteLayout from '../layouts/SiteLayout.astro';
import { lightStyles, site } from '../data/site';

const pageTitle = `Light Styles | ${site.name}`;
const pageDescription = 'A visual guide to the kinds of WLED-compatible lighting Arcline installs.';
---

<SiteLayout title={pageTitle} description={pageDescription} image={site.primaryImage}>
	<main class="page-shell">
		<section class="page-hero narrow-hero">
			<p class="eyebrow">Light styles</p>
			<h1>Choose by feel, not by spec sheet.</h1>
			<p class="lede">
				This page is about how different lighting styles read in a room or on a house. It is meant to
				help you picture the result before getting pulled into technical details.
			</p>
		</section>

		<section class="style-list">
			{
				lightStyles.map((style) => (
					<article class="style-card card">
						<div class="style-image">
							<img src={style.image} alt={style.title} loading="lazy" />
						</div>
						<div class="style-copy">
							<h2>{style.title}</h2>
							<p>{style.description}</p>
							<p><strong>Best for:</strong> {style.bestFor}</p>
						</div>
					</article>
				))
			}
		</section>
	</main>
</SiteLayout>

<style>
	.narrow-hero {
		max-width: 52rem;
	}
	.style-list {
		display: grid;
		gap: 1.25rem;
	}
	.style-card {
		display: grid;
		grid-template-columns: 320px 1fr;
		gap: 1.25rem;
		align-items: center;
	}
	.style-image img {
		width: 100%;
		height: 100%;
		min-height: 240px;
		object-fit: cover;
		box-shadow: var(--panel-shadow);
	}
	.style-copy h2 {
		font-size: 1.6rem;
		margin-bottom: 0.6rem;
	}
	@media (max-width: 780px) {
		.style-card {
			grid-template-columns: 1fr;
		}
	}
</style>
